/* تنسيق حاوية المنتج */
.product-card {
    background: #ffffff;
    border: 1px solid #eee;
    border-radius: 15px;
    padding: 15px;
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

/* تأثير عند تمرير الماوس - لمسة ذهبية */
.product-card:hover {
    border-color: #C5A021;
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(197, 160, 33, 0.2);
}

/* صورة المنتج */
.product-card img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    margin-bottom: 15px;
}

/* اسم المنتج */
.product-card h3 {
    color: #002366;
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 10px;
}

/* السعر باللون الذهبي */
.product-price {
    color: #C5A021;
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 15px;
}

/* زر إضافة للسلة الاحترافي */
.add-to-cart-btn {
    background: #002366;
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    width: 100%;
    transition: background 0.3s ease;
}

.add-to-cart-btn:hover {
    background: #C5A021;
}
