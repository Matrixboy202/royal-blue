{% extends "layouts.master" %}

{% block content %}
    {# قسم الترحيب الملكي #}
    <section style="background: linear-gradient(rgba(0, 35, 102, 0.8), rgba(0, 35, 102, 0.8)), url('{{ theme.settings.hero_image }}'); background-size: cover; padding: 120px 20px; color: white; text-align: center;">
        <div class="container">
            <h1 style="font-size: 3.5rem; color: #C5A021; margin-bottom: 20px;">أبو حاتم للعطارة</h1>
            <p style="font-size: 1.6rem; max-width: 700px; margin: 0 auto 30px;">نقدم لكم أجود أنواع الحناء والسدر والأعشاب الطبيعية.. عناية ملكية من قلب الطبيعة.</p>
            <a href="/products" class="s-button-primary" style="padding: 15px 40px; font-size: 1.2rem; text-decoration: none;">تسوّق الآن</a>
        </div>
    </section>

    {# قسم مميزات المتجر #}
    <section style="padding: 60px 0; background-color: #FDFBF7;">
        <div style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px;">
            <div style="text-align: center;">
                <span style="font-size: 40px;">🌿</span>
                <h3 style="color: #002366;">عضوي 100%</h3>
            </div>
            <div style="text-align: center;">
                <span style="font-size: 40px;">💎</span>
                <h3 style="color: #002366;">جودة ملكية</h3>
            </div>
            <div style="text-align: center;">
                <span style="font-size: 40px;">🚚</span>
                <h3 style="color: #002366;">توصيل سريع</h3>
            </div>
        </div>
    </section>
{% endblock %}
