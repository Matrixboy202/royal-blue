{% extends "layouts.master" %}

{% block content %}
    {# تنسيقات الحقن المباشر - القوة القصوى #}
    <style>
        header.main-header { background: #ffffff !important; border-bottom: 3px solid #C5A021 !important; }
h2 {
    margin-top: 50px !important;
    font-size: 2.5rem !important;
    letter-spacing: -1px;
}
        .header-action-btn i, .header-action-btn svg { color: #002366 !important; }
        .top-header { background-color: #002366 !important; }
        .top-header * { color: #C5A021 !important; }
        .search-bar { border: 2px solid #C5A021 !important; border-radius: 25px !important; }
        * { font-family: 'Tajawal', sans-serif !important; }
    </style>

    {# 1. البنر الملكي #}
    <section style="position: relative; min-height: 450px; display: flex; align-items: center; justify-content: center; background: linear-gradient(rgba(0,35,102,0.6), rgba(0,35,102,0.6)), url('https://images.unsplash.com/photo-1596040033229-a9821ebd058d?q=80&w=2070&auto=format&fit=crop'); background-size: cover; background-position: center; border-bottom: 5px solid #C5A021;">
        <div style="text-align: center; color: white; padding: 20px;">
            <h1 style="font-size: 3.5rem; color: #C5A021; font-weight: 900; margin-bottom: 10px;">أبو حاتم للعطارة</h1>
            <p style="font-size: 1.4rem; margin-bottom: 30px;">نقاء الطبيعة وأصالة التراث في متناول يدك</p>
            <a href="/products" style="background: #C5A021; color: #002366; padding: 15px 45px; border-radius: 50px; text-decoration: none; font-weight: bold; display: inline-block;">تسوّق الآن</a>
        </div>
    </section>

    {# 2. قسم المميزات #}
    <div style="background: #fff; padding: 40px 0; border-bottom: 1px solid #eee;">
        <div class="container" style="display: flex; justify-content: space-around; flex-wrap: wrap; text-align: center; gap: 20px;">
            <div style="flex: 1; min-width: 200px;"><span>🌿</span><h4 style="color: #002366;">أعشاب عضوية 100%</h4></div>
            <div style="flex: 1; min-width: 200px;"><span>🏆</span><h4 style="color: #002366;">جودة ملكية مختارة</h4></div>
            <div style="flex: 1; min-width: 200px;"><span>🚚</span><h4 style="color: #002366;">توصيل لكافة المناطق</h4></div>
        </div>
    </div>

    {# 3. قسم المنتجات #}
    <section style="background-color: #FDFBF7; padding: 60px 0;">
        <div class="container">
            <h2 style="color: #002366; text-align: center; margin-bottom: 40px; border-bottom: 3px solid #C5A021; display: inline-block; padding-bottom: 10px;">منتجاتنا الفاخرة</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
                {% for product in products %}
                    {# كود عرض المنتج هنا #}
                {% else %}
                    <p style="text-align: center; grid-column: 1 / -1; color: #666; padding: 40px;">أضف منتجك الأول من لوحة التحكم ليظهر هنا بفخامة.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    {# 4. قسم التقييمات #}
    <section style="background-color: #fff; padding: 60px 0;">
        <div class="container" style="text-align: center;">
            <h2 style="color: #002366; margin-bottom: 30px;">قالوا عن "أبو حاتم"</h2>
            <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 20px;">
                <div style="background: #FDFBF7; padding: 20px; border-radius: 15px; border-right: 4px solid #C5A021; max-width: 300px;">
                    <p>"جودة الحناء تفوق الوصف، شكراً لكم."</p>
                    <strong style="color: #002366;">سارة العتيبي</strong>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
