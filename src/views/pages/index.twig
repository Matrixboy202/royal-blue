{% extends "layouts.master" %}

{% block content %}
    {# 1. قسم الترحيب (Hero Section) #}
    <section class="hero-royal" style="background: linear-gradient(135deg, #002366 0%, #001a4d 100%); padding: 100px 20px; text-align: center; border-bottom: 4px solid #C5A021; position: relative; overflow: hidden;">
        <div class="container" style="position: relative; z-index: 2;">
            <h1 style="color: #C5A021; font-size: 3.5rem; font-weight: 900; margin-bottom: 15px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">أبو حاتم للعطارة</h1>
            <p style="color: #FDFBF7; font-size: 1.4rem; max-width: 800px; margin: 0 auto 35px; line-height: 1.8;">نقاء الطبيعة وأصالة التراث في منتجاتنا من الحناء والسدر والأعشاب العضوية</p>
            <a href="/products" class="s-button-primary" style="background: #C5A021; color: #002366; padding: 18px 50px; border-radius: 50px; font-weight: bold; font-size: 1.2rem; text-decoration: none; box-shadow: 0 10px 20px rgba(0,0,0,0.2); transition: 0.3s;">تسوّق الآن</a>
        </div>
    </section>

    {# 2. قسم المميزات السريع #}
    <div style="background: #fff; padding: 40px 0; border-bottom: 1px solid #eee;">
        <div class="container" style="display: flex; justify-content: space-around; flex-wrap: wrap; text-align: center; gap: 20px;">
            <div style="flex: 1; min-width: 200px;">
                <span style="font-size: 30px; display: block; margin-bottom: 10px;">🌿</span>
                <h4 style="color: #002366; font-weight: bold;">أعشاب عضوية 100%</h4>
            </div>
            <div style="flex: 1; min-width: 200px;">
                <span style="font-size: 30px; display: block; margin-bottom: 10px;">🏆</span>
                <h4 style="color: #002366; font-weight: bold;">جودة ملكية مختارة</h4>
            </div>
            <div style="flex: 1; min-width: 200px;">
                <span style="font-size: 30px; display: block; margin-bottom: 10px;">🚚</span>
                <h4 style="color: #002366; font-weight: bold;">توصيل لكافة المناطق</h4>
            </div>
        </div>
    </div>

    {# 3. قسم عرض المنتجات (هنا السحر!) #}
    <section style="background-color: #FDFBF7; padding: 80px 0;">
        <div class="container">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px; border-right: 5px solid #C5A021; padding-right: 20px;">
                <h2 style="color: #002366; font-size: 2.2rem; font-weight: bold; margin: 0;">منتجاتنا الفاخرة</h2>
                <a href="/products" style="color: #C5A021; text-decoration: none; font-weight: bold;">مشاهدة الكل ←</a>
            </div>

            {# شبكة المنتجات #}
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
                {% for product in products %}
                    <div class="product-card-royal" style="background: #fff; border-radius: 20px; padding: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: 0.4s; border: 1px solid transparent;">
                        <div style="background: #f9f9f9; border-radius: 15px; margin-bottom: 15px; overflow: hidden; height: 250px;">
                            <img src="{{ product.image.url }}" alt="{{ product.name }}" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <h3 style="color: #002366; font-size: 1.2rem; margin-bottom: 10px; font-weight: bold;">{{ product.name }}</h3>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
                            <span style="color: #C5A021; font-weight: bold; font-size: 1.3rem;">{{ product.price | money }}</span>
                            <button class="s-button-primary" style="background: #002366; color: #fff; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer;">أضف للسلة</button>
                        </div>
                    </div>
                {% else %}
                    {# في حال لا توجد منتجات حالياً #}
                    <p style="text-align: center; grid-column: 1 / -1; color: #666;">سيتم عرض المنتجات هنا بمجرد إضافتها للمتجر.</p>
                {% endfor %}
            </div>
        </div>
    </section>
{# 4. قسم آراء العملاء الملكي #}
<section style="background-color: #fff; padding: 80px 0; border-top: 1px solid #eee;">
    <div class="container">
        <div style="text-align: center; margin-bottom: 50px;">
            <h2 style="color: #002366; font-size: 2.2rem; font-weight: bold;">قالوا عن "أبو حاتم للعطارة"</h2>
            <div style="color: #C5A021; font-size: 1.2rem; margin-top: 10px;">⭐⭐⭐⭐⭐</div>
        </div>

        <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 25px;">
            
            {# التقييم الأول #}
            <div style="flex: 1; min-width: 300px; max-width: 350px; background: #FDFBF7; padding: 30px; border-radius: 20px; border-right: 4px solid #C5A021; box-shadow: 0 5px 15px rgba(0,0,0,0.02);">
                <p style="color: #444; font-style: italic; margin-bottom: 20px; line-height: 1.6;">"ما شاء الله، الحناء جداً نظيفة واللون طلع خيالي من أول مرة. التوصيل كان سريع والتعامل راقي جداً."</p>
                <div style="font-weight: bold; color: #002366;">سارة العتيبي</div>
                <div style="font-size: 12px; color: #888;">عميل موثق ✅</div>
            </div>

            {# التقييم الثاني #}
            <div style="flex: 1; min-width: 300px; max-width: 350px; background: #FDFBF7; padding: 30px; border-radius: 20px; border-right: 4px solid #C5A021; box-shadow: 0 5px 15px rgba(0,0,0,0.02);">
                <p style="color: #444; font-style: italic; margin-bottom: 20px; line-height: 1.6;">"جربت السدر المطحون، فعلاً أصلي وبدون شوائب. اهتمامكم بالتغليف والجودة واضح جداً. الله يبارك لكم."</p>
                <div style="font-weight: bold; color: #002366;">محمد خالد</div>
                <div style="font-size: 12px; color: #888;">عميل موثق ✅</div>
            </div>

            {# التقييم الثالث #}
            <div style="flex: 1; min-width: 300px; max-width: 350px; background: #FDFBF7; padding: 30px; border-radius: 20px; border-right: 4px solid #C5A021; box-shadow: 0 5px 15px rgba(0,0,0,0.02);">
                <p style="color: #444; font-style: italic; margin-bottom: 20px; line-height: 1.6;">"أفضل زيوت جربتها لشعري، النتيجة مبهرة. شكراً أبو حاتم على هذه الأمانة في المنتجات."</p>
                <div style="font-weight: bold; color: #002366;">أم نورة</div>
                <div style="font-size: 12px; color: #888;">عميل موثق ✅</div>
            </div>

        </div>
    </div>
</section>
{% endblock %}
